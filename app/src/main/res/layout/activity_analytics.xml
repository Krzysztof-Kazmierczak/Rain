<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAnalytics"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Analiza i Historia"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:navigationIconTint="@android:color/white"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="POGODA:" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                <CheckBox android:id="@+id/cbTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temp (°C)" android:checked="true" />
                <CheckBox android:id="@+id/cbRain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Opady" android:layout_marginStart="8dp" android:checked="true"/>
                <CheckBox android:id="@+id/cbClouds" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chmury (%)" android:layout_marginStart="8dp" />

                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCC" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DANE Z POLA:" android:textStyle="bold" android:layout_marginEnd="8dp"/>
                <CheckBox android:id="@+id/cbSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prędkość" android:checked="true"/>
                <CheckBox android:id="@+id/cbWind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wiatr (m/s)" android:layout_marginStart="8dp"/>
                <CheckBox android:id="@+id/cbHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wilgotność" android:layout_marginStart="8dp"/>

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupInterval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip1h"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1h"
            android:checked="true"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip3h"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3h"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip12h"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12h"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDay"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Dzień"/>
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="10">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartWeather"
                android:layout_width="match_parent"
                android:layout_height="300dp" />

            <ImageButton
                android:id="@+id/btnToggleForecast"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_visibility"
                android:tooltipText="Pokaż/Ukryj Prognozę"
                app:tint="@android:color/darker_gray" />
        </FrameLayout>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartMachine"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"
            android:layout_margin="8dp"/>
    </LinearLayout>

</LinearLayout>