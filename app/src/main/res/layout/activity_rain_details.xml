<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dane urządzenia"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/nameEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nazwa deszczowni" />

            <EditText
                android:id="@+id/lengthEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Długość węża (m)"
                android:inputType="number" />

            <EditText
                android:id="@+id/commentEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Komentarz" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/statusHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aktualny status pracy"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Pobieranie..."
                android:textSize="16sp"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/currentSpeedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prędkość: -- m/h"
                android:textSize="16sp"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/timeFinishText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Czas do końca: --"
                android:textSize="16sp"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/workTimeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Czas pracy: --"
                android:textSize="16sp"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/extensionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rozwinięcie: -- m"
                android:textSize="16sp"
                android:padding="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center">

                <Button
                    android:id="@+id/saveButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ZAPISZ"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnAdvancedSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ZAAWANSOWANE"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>