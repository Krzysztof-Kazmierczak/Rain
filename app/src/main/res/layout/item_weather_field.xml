<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
    app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFieldName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nazwa Pola"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvFieldCrop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌾 Uprawa: Pszenica"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/adviceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#E8F5E9"> <TextView
            android:id="@+id/tvAdviceTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Ładowanie doradcy..."
            android:textStyle="bold"
            android:textColor="#1B5E20"/>

            <TextView
                android:id="@+id/tvAdviceMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sprawdzam chmury..."
                android:textColor="#333333"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>